{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "circuitpython-wasm-magic",
  "title": "CircuitPython WASM Board Magic (On-Board Components)",
  "description": "Declares on-board components that are auto-configured at boot. Adapted from WipperSnapper's magic.json concept. These represent components soldered to the board (not external peripherals).",
  "type": "object",
  "properties": {
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "name"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "led", "neopixel", "dotstar", "push_button",
              "light_sensor", "temperature_sensor",
              "accelerometer", "speaker", "piezo_buzzer",
              "display_tft", "display_oled",
              "i2c_sensor", "ir_receiver", "ir_transmitter"
            ]
          },
          "name": {
            "type": "string",
            "description": "Human label (e.g., 'Status LED', 'NeoPixel Strip')"
          },
          "pin": {
            "type": "string",
            "description": "Board pin name (e.g., 'D13', 'NEOPIXEL')"
          },

          "led": {
            "type": "object",
            "description": "LED-specific config",
            "properties": {
              "color": { "type": "string", "default": "red" },
              "activeHigh": { "type": "boolean", "default": true }
            }
          },

          "neopixel": {
            "type": "object",
            "description": "NeoPixel-specific config",
            "properties": {
              "count": { "type": "integer" },
              "order": { "type": "string", "enum": ["GRB", "GRBW", "RGB", "RGBW", "BGR"], "default": "GRB" },
              "brightness": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.2 }
            }
          },

          "button": {
            "type": "object",
            "description": "Push button config",
            "properties": {
              "pull": { "type": "string", "enum": ["UP", "DOWN"], "default": "UP" },
              "activeHigh": { "type": "boolean", "default": false }
            }
          },

          "sensor": {
            "type": "object",
            "description": "Sensor config (for light_sensor, temperature_sensor, etc.)",
            "properties": {
              "mode": { "type": "string", "enum": ["analog", "digital", "i2c"] },
              "range": {
                "type": "object",
                "properties": {
                  "min": { "type": "number" },
                  "max": { "type": "number" },
                  "unit": { "type": "string" }
                }
              },
              "defaultValue": { "type": "number" }
            }
          },

          "i2c_device": {
            "type": "object",
            "description": "On-board I2C device config",
            "properties": {
              "address": { "type": "integer" },
              "bus": { "type": "integer", "default": 0 },
              "component": {
                "type": "string",
                "description": "Reference to a component definition (e.g., 'lis3dh', 'bme280')"
              }
            }
          },

          "display": {
            "type": "object",
            "description": "Display config",
            "properties": {
              "width": { "type": "integer" },
              "height": { "type": "integer" },
              "driver": { "type": "string" },
              "rotation": { "type": "integer", "default": 0 }
            }
          },

          "visual": {
            "type": "object",
            "description": "Position on board SVG for interactive rendering",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "w": { "type": "number" },
              "h": { "type": "number" },
              "shape": { "type": "string", "enum": ["circle", "rect", "strip", "ring", "custom"] },
              "svgElement": { "type": "string", "description": "CSS selector for existing SVG element to bind to" }
            }
          }
        }
      }
    }
  }
}
