{
  "componentName": "tmp117",
  "displayName": "TMP117",
  "vendor": "Texas Instruments",
  "type": "i2c",
  "productURL": "https://www.adafruit.com/product/4821",
  "documentationURL": "https://learn.adafruit.com/adafruit-tmp117-high-accuracy-i2c-temperature-monitor",
  "driver": {
    "package": "adafruit_tmp117",
    "repo": "https://github.com/adafruit/adafruit_circuitpython_tmp117",
    "importName": "adafruit_tmp117"
  },
  "i2c": {
    "addresses": [
      72,
      73,
      74,
      75
    ],
    "defaultAddress": 72,
    "registers": []
  },
  "sensors": [
    {
      "type": "ambient-temp",
      "displayName": "Temperature Sensor (\u00b0C)",
      "unit": "\u00b0C",
      "range": {
        "min": -40,
        "max": 85
      },
      "defaultValue": 22,
      "defaultPeriod": 0.9
    },
    {
      "type": "ambient-temp-fahrenheit",
      "displayName": "Temperature Sensor (\u00b0F)",
      "unit": "\u00b0F",
      "range": {
        "min": -40,
        "max": 185
      },
      "defaultValue": 72,
      "defaultPeriod": 0.9
    }
  ],
  "visual": {
    "icon": "thermometer",
    "color": "#e74c3c",
    "widget": "slider"
  }
}
