{
  "componentName": "ms8607",
  "displayName": "MS8607",
  "vendor": "TE Connectivity",
  "type": "i2c",
  "productURL": "https://www.adafruit.com/product/4716",
  "documentationURL": "https://learn.adafruit.com/adafruit-te-ms8607-pht-sensor",
  "driver": {
    "package": "adafruit_ms8607",
    "repo": "https://github.com/adafruit/adafruit_circuitpython_ms8607",
    "importName": "adafruit_ms8607"
  },
  "i2c": {
    "addresses": [
      64,
      118
    ],
    "defaultAddress": 64,
    "registers": []
  },
  "sensors": [
    {
      "type": "ambient-temp",
      "displayName": "Temperature Sensor (\u00b0C)",
      "unit": "\u00b0C",
      "range": {
        "min": -40,
        "max": 85
      },
      "defaultValue": 22,
      "defaultPeriod": 0.9
    },
    {
      "type": "ambient-temp-fahrenheit",
      "displayName": "Temperature Sensor (\u00b0F)",
      "unit": "\u00b0F",
      "range": {
        "min": -40,
        "max": 185
      },
      "defaultValue": 72,
      "defaultPeriod": 0.9
    },
    {
      "type": "humidity",
      "displayName": "Humidity Sensor",
      "unit": "%RH",
      "range": {
        "min": 0,
        "max": 100
      },
      "defaultValue": 45,
      "defaultPeriod": 0.9
    },
    {
      "type": "pressure",
      "displayName": "Pressure Sensor",
      "unit": "hPa",
      "range": {
        "min": 300,
        "max": 1100
      },
      "defaultValue": 1013.25,
      "defaultPeriod": 0.9
    }
  ],
  "visual": {
    "icon": "thermometer",
    "color": "#e74c3c",
    "widget": "slider"
  }
}
