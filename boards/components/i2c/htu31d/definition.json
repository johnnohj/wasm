{
  "componentName": "htu31d",
  "displayName": "HTU31D",
  "vendor": "TE Connectivity",
  "type": "i2c",
  "productURL": "https://www.adafruit.com/product/2857",
  "documentationURL": "https://www.adafruit.com/product/4832",
  "driver": {
    "package": "adafruit_htu31d",
    "repo": "https://github.com/adafruit/adafruit_circuitpython_htu31d",
    "importName": "adafruit_htu31d"
  },
  "i2c": {
    "addresses": [
      64,
      65
    ],
    "defaultAddress": 64,
    "registers": []
  },
  "sensors": [
    {
      "type": "ambient-temp",
      "displayName": "Temperature Sensor (\u00b0C)",
      "unit": "\u00b0C",
      "range": {
        "min": -40,
        "max": 85
      },
      "defaultValue": 22,
      "defaultPeriod": 0.9
    },
    {
      "type": "ambient-temp-fahrenheit",
      "displayName": "Temperature Sensor (\u00b0F)",
      "unit": "\u00b0F",
      "range": {
        "min": -40,
        "max": 185
      },
      "defaultValue": 72,
      "defaultPeriod": 0.9
    },
    {
      "type": "humidity",
      "displayName": "Humidity Sensor",
      "unit": "%RH",
      "range": {
        "min": 0,
        "max": 100
      },
      "defaultValue": 45,
      "defaultPeriod": 0.9
    }
  ],
  "visual": {
    "icon": "thermometer",
    "color": "#e74c3c",
    "widget": "slider"
  }
}
