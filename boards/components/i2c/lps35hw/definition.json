{
  "componentName": "lps35hw",
  "displayName": "LPS35HW",
  "vendor": "STMicroelectronics",
  "type": "i2c",
  "productURL": "https://www.adafruit.com/product/4258",
  "documentationURL": "https://learn.adafruit.com/lps35hw-water-resistant-pressure-sensor",
  "driver": {
    "package": "adafruit_lps35hw",
    "repo": "https://github.com/adafruit/adafruit_circuitpython_lps35hw",
    "importName": "adafruit_lps35hw"
  },
  "i2c": {
    "addresses": [
      93,
      92
    ],
    "defaultAddress": 93,
    "registers": []
  },
  "sensors": [
    {
      "type": "ambient-temp",
      "displayName": "Temperature Sensor (\u00b0C)",
      "unit": "\u00b0C",
      "range": {
        "min": -40,
        "max": 85
      },
      "defaultValue": 22,
      "defaultPeriod": 0.9
    },
    {
      "type": "ambient-temp-fahrenheit",
      "displayName": "Temperature Sensor (\u00b0F)",
      "unit": "\u00b0F",
      "range": {
        "min": -40,
        "max": 185
      },
      "defaultValue": 72,
      "defaultPeriod": 0.9
    },
    {
      "type": "pressure",
      "displayName": "Pressure Sensor",
      "unit": "hPa",
      "range": {
        "min": 300,
        "max": 1100
      },
      "defaultValue": 1013.25,
      "defaultPeriod": 0.9
    }
  ],
  "visual": {
    "icon": "thermometer",
    "color": "#e74c3c",
    "widget": "slider"
  }
}
