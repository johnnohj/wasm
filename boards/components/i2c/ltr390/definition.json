{
  "componentName": "ltr390",
  "displayName": "LTR-390",
  "vendor": "LITE-ON",
  "type": "i2c",
  "productURL": "https://www.adafruit.com/product/4831",
  "documentationURL": "https://learn.adafruit.com/adafruit-ltr390-uv-sensor",
