{
  "componentName": "bme280",
  "displayName": "BME280 Temperature/Humidity/Pressure",
  "vendor": "Bosch",
  "type": "i2c",
  "productURL": "https://www.adafruit.com/product/2652",
  "documentationURL": "https://learn.adafruit.com/adafruit-bme280-humidity-barometric-pressure-temperature-sensor-breakout",

  "driver": {
    "package": "adafruit_bme280",
    "repo": "https://github.com/adafruit/Adafruit_CircuitPython_BME280",
    "importName": "adafruit_bme280.basic",
    "example": "import board, busio\nfrom adafruit_bme280 import basic as adafruit_bme280\ni2c = busio.I2C(board.SCL, board.SDA)\nbme = adafruit_bme280.Adafruit_BME280_I2C(i2c)\nprint(bme.temperature, bme.humidity, bme.pressure)"
  },

  "i2c": {
    "addresses": [119, 118],
    "defaultAddress": 119,
    "registers": [
      { "address": 208, "name": "chip_id",    "access": "r",  "defaultValue": 96, "description": "Chip ID (0x60 for BME280)" },
      { "address": 244, "name": "ctrl_meas",  "access": "rw", "defaultValue": 0,  "description": "Measurement control" },
      { "address": 245, "name": "status",     "access": "r",  "defaultValue": 0,  "description": "Status register" },
      { "address": 247, "name": "press_msb",  "access": "r",  "defaultValue": 128, "description": "Pressure MSB" },
      { "address": 248, "name": "press_lsb",  "access": "r",  "defaultValue": 0 },
      { "address": 249, "name": "press_xlsb", "access": "r",  "defaultValue": 0 },
      { "address": 250, "name": "temp_msb",   "access": "r",  "defaultValue": 128, "description": "Temperature MSB" },
      { "address": 251, "name": "temp_lsb",   "access": "r",  "defaultValue": 0 },
      { "address": 252, "name": "temp_xlsb",  "access": "r",  "defaultValue": 0 },
      { "address": 253, "name": "hum_msb",    "access": "r",  "defaultValue": 128, "description": "Humidity MSB" },
      { "address": 254, "name": "hum_lsb",    "access": "r",  "defaultValue": 0 }
    ]
  },

  "sensors": [
    { "type": "ambient-temp", "displayName": "Temperature", "unit": "°C",
      "range": { "min": -40, "max": 85 }, "defaultValue": 22, "defaultPeriod": 2 },
    { "type": "humidity", "displayName": "Humidity", "unit": "%RH",
      "range": { "min": 0, "max": 100 }, "defaultValue": 45, "defaultPeriod": 2 },
    { "type": "pressure", "displayName": "Barometric Pressure", "unit": "hPa",
      "range": { "min": 300, "max": 1100 }, "defaultValue": 1013.25, "defaultPeriod": 2 }
  ],

  "visual": {
    "icon": "thermometer",
    "color": "#e74c3c",
    "widget": "gauge"
  }
}
