{
  "componentName": "si7021",
  "displayName": "Si7021",
  "vendor": "Silicon Labs",
  "type": "i2c",
  "productURL": "https://www.adafruit.com/product/3251",
  "documentationURL": "https://learn.adafruit.com/adafruit-si7021-temperature-plus-humidity-sensor/overview",
  "driver": {
    "package": "adafruit_si7021",
    "repo": "https://github.com/adafruit/adafruit_circuitpython_si7021",
    "importName": "adafruit_si7021"
  },
  "i2c": {
    "addresses": [
      64
    ],
    "defaultAddress": 64,
    "registers": []
  },
  "sensors": [
    {
      "type": "ambient-temp",
      "displayName": "Temperature Sensor (\u00b0C)",
      "unit": "\u00b0C",
      "range": {
        "min": -40,
        "max": 85
      },
      "defaultValue": 22,
      "defaultPeriod": 0.9
    },
    {
      "type": "ambient-temp-fahrenheit",
      "displayName": "Temperature Sensor (\u00b0F)",
      "unit": "\u00b0F",
      "range": {
        "min": -40,
        "max": 185
      },
      "defaultValue": 72,
      "defaultPeriod": 0.9
    },
    {
      "type": "humidity",
      "displayName": "Humidity Sensor",
      "unit": "%RH",
      "range": {
        "min": 0,
        "max": 100
      },
      "defaultValue": 45,
      "defaultPeriod": 0.9
    }
  ],
  "visual": {
    "icon": "thermometer",
    "color": "#e74c3c",
    "widget": "slider"
  }
}
