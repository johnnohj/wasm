{
  "componentName": "scd30",
  "displayName": "SCD30",
  "vendor": "Sensirion",
  "type": "i2c",
  "productURL": "https://www.adafruit.com/product/4867",
  "documentationURL": "https://learn.adafruit.com/adafruit-scd30",
  "driver": {
    "package": "adafruit_scd30",
    "repo": "https://github.com/adafruit/adafruit_circuitpython_scd30",
    "importName": "adafruit_scd30"
  },
  "i2c": {
    "addresses": [
      97
    ],
    "defaultAddress": 97,
    "registers": []
  },
  "sensors": [
    {
      "type": "ambient-temp",
      "displayName": "Temperature Sensor (\u00b0C)",
      "unit": "\u00b0C",
      "range": {
        "min": -40,
        "max": 85
      },
      "defaultValue": 22,
      "defaultPeriod": 0.9
    },
    {
      "type": "ambient-temp-fahrenheit",
      "displayName": "Temperature Sensor (\u00b0F)",
      "unit": "\u00b0F",
      "range": {
        "min": -40,
        "max": 185
      },
      "defaultValue": 72,
      "defaultPeriod": 0.9
    },
    {
      "type": "humidity",
      "displayName": "Humidity Sensor",
      "unit": "%RH",
      "range": {
        "min": 0,
        "max": 100
      },
      "defaultValue": 45,
      "defaultPeriod": 0.9
    },
    {
      "type": "co2",
      "displayName": "CO2",
      "unit": "ppm",
      "range": {
        "min": 400,
        "max": 8192
      },
      "defaultValue": 400,
      "defaultPeriod": 0.9
    }
  ],
  "visual": {
    "icon": "thermometer",
    "color": "#e74c3c",
    "widget": "slider"
  }
}
