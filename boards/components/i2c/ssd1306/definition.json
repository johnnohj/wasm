{
  "componentName": "ssd1306",
  "displayName": "SSD1306 OLED Display (128x64)",
  "vendor": "Solomon Systech",
  "type": "i2c",
  "productURL": "https://www.adafruit.com/product/326",
  "documentationURL": "https://learn.adafruit.com/monochrome-oled-breakouts",

  "driver": {
    "package": "adafruit_ssd1306",
    "repo": "https://github.com/adafruit/Adafruit_CircuitPython_SSD1306",
    "importName": "adafruit_ssd1306",
    "example": "import board, busio, adafruit_ssd1306\ni2c = busio.I2C(board.SCL, board.SDA)\noled = adafruit_ssd1306.SSD1306_I2C(128, 64, i2c)\noled.text('Hello!', 0, 0, 1)\noled.show()"
  },

  "i2c": {
    "addresses": [60, 61],
    "defaultAddress": 60,
    "registers": [
      { "address": 0,  "name": "command", "access": "w", "description": "Command register" }
    ]
  },

  "sensors": [],

  "visual": {
    "icon": "display",
    "color": "#2ecc71",
    "widget": "text"
  }
}
