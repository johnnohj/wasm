{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "circuitpython-wasm-component",
  "title": "CircuitPython WASM Component Definition",
  "description": "Describes an external component (sensor, display, actuator) that can be connected to the simulated board. Adapted from WipperSnapper's component definitions, enriched with fwip source info for driver installation.",
  "type": "object",
  "required": ["componentName", "displayName", "type"],
  "properties": {
    "componentName": {
      "type": "string",
      "description": "Machine-readable ID matching fwip package name (e.g., 'bme280', 'lis3dh')"
    },
    "displayName": {
      "type": "string",
      "description": "Human-readable name (e.g., 'BME280 Temperature/Humidity/Pressure')"
    },
    "vendor": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["i2c", "spi", "uart", "digital", "analog", "neopixel", "display"]
    },
    "productURL": { "type": "string", "format": "uri" },
    "documentationURL": { "type": "string", "format": "uri" },

    "driver": {
      "type": "object",
      "description": "CircuitPython driver info for fwip installation",
      "properties": {
        "package": {
          "type": "string",
          "description": "fwip package name (e.g., 'adafruit_bme280')"
        },
        "repo": {
          "type": "string",
          "format": "uri",
          "description": "GitHub repo URL for the driver"
        },
        "importName": {
          "type": "string",
          "description": "Python import path (e.g., 'adafruit_bme280.basic')"
        },
        "example": {
          "type": "string",
          "description": "Minimal usage example (Python code snippet)"
        }
      }
    },

    "i2c": {
      "type": "object",
      "description": "I2C device specifics",
      "properties": {
        "addresses": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "Valid I2C addresses (e.g., [0x77, 0x76])"
        },
        "defaultAddress": { "type": "integer" },
        "registers": {
          "type": "array",
          "description": "Register map for simulation (optional — enables virtual device)",
          "items": {
            "type": "object",
            "properties": {
              "address": { "type": "integer" },
              "name": { "type": "string" },
              "size": { "type": "integer", "default": 1 },
              "access": { "type": "string", "enum": ["r", "w", "rw"], "default": "r" },
              "defaultValue": { "type": "integer" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },

    "sensors": {
      "type": "array",
      "description": "Sensor readings this component provides",
      "items": {
        "type": "object",
        "required": ["type", "displayName"],
        "properties": {
          "type": {
            "type": "string",
            "description": "Sensor type slug",
            "enum": [
              "ambient-temp", "ambient-temp-fahrenheit",
              "humidity", "pressure", "altitude",
              "light", "color", "proximity", "gesture",
              "accel-x", "accel-y", "accel-z",
              "gyro-x", "gyro-y", "gyro-z",
              "mag-x", "mag-y", "mag-z",
              "co2", "tvoc", "pm25", "pm10",
              "sound-level", "voltage", "current",
              "distance", "soil-moisture",
              "raw"
            ]
          },
          "displayName": { "type": "string" },
          "unit": { "type": "string" },
          "range": {
            "type": "object",
            "properties": {
              "min": { "type": "number" },
              "max": { "type": "number" }
            }
          },
          "defaultValue": { "type": "number" },
          "defaultPeriod": {
            "type": "number",
            "description": "Default polling period in seconds"
          }
        }
      }
    },

    "visual": {
      "type": "object",
      "description": "How to render this component when connected",
      "properties": {
        "icon": { "type": "string", "description": "SVG icon filename or data URI" },
        "color": { "type": "string" },
        "widget": {
          "type": "string",
          "enum": ["slider", "gauge", "toggle", "graph", "color_picker", "text", "led_strip"],
          "description": "Default UI widget for sensor values"
        }
      }
    }
  }
}
